<Window x:Class="MrezaCuttingPlan.UI.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plan Rezanja Mreža – Postavke"
        Width="460" Height="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Naslov -->
        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="Standardni lim i putanja PDF izvještaja"
                   FontWeight="Bold" FontSize="13"
                   Margin="0,0,0,15"/>

        <!-- Širina lima -->
        <TextBlock Grid.Row="1" Grid.Column="0"
                   Text="Širina standardnog lima (cm):"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtSheetWidth"
                 Text="215"
                 Padding="5,3"
                 Margin="0,5"
                 VerticalAlignment="Center"/>

        <!-- Dužina lima -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Text="Dužina standardnog lima (cm):"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                 x:Name="TxtSheetLength"
                 Text="600"
                 Padding="5,3"
                 Margin="0,5"
                 VerticalAlignment="Center"/>

        <!-- PDF putanja -->
        <TextBlock Grid.Row="3" Grid.Column="0"
                   Text="Putanja PDF izvještaja:"
                   VerticalAlignment="Center" Margin="0,5"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 x:Name="TxtPdfPath"
                 Padding="5,3"
                 Margin="0,5,5,5"
                 VerticalAlignment="Center"
                 IsReadOnly="True"/>
        <Button Grid.Row="3" Grid.Column="2"
                Content="Pretraži..."
                Padding="8,3"
                Margin="0,5"
                Click="BtnBrowse_Click"/>

        <!-- Napomena -->
        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                   Text="Napomena: R-mreže se ne rotiraju (smjer žica). Q-mreže se mogu rotirati za 90°."
                   FontStyle="Italic" FontSize="10"
                   Foreground="Gray"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"/>

        <!-- Gumbi -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button x:Name="BtnOk"
                    Content="Generiraj"
                    Width="100" Padding="0,5"
                    Margin="0,0,10,0"
                    IsDefault="True"
                    Click="BtnOk_Click"/>
            <Button Content="Odustani"
                    Width="80" Padding="0,5"
                    IsCancel="True"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
